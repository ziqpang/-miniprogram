page {
  background-color: #f5f5f7;
  color: #111827;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text",
    "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.container {
  padding: 32rpx;
  box-sizing: border-box;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
}

.section-subtitle {
  font-size: 24rpx;
  color: #9ca3af;
}