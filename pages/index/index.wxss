/* 容器 */
.container {
  padding: 32rpx;
  box-sizing: border-box;
}

/* 公共区块标题在卡片外 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
}

.section-subtitle {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 月历整体卡片（上下都圆角） */
.calendar-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx 20rpx 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.06);
  margin-bottom: 32rpx;
}

/* 纵向月历 swiper，高度显示完整 6 行 */
.month-swiper {
  height: 720rpx;
}

/* 单个月内容卡片 */
.month-card {
  border-radius: 16rpx;
  padding-bottom: 24rpx;
}

/* 月头部 */
.month-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.month-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.month-subtitle {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.month-tag {
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  color: #4b5563;
  border-radius: 999rpx;
  border: 1rpx solid #e5e7eb;
  background-color: #f9fafb;
}

/* 星期头部 */
.week-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 8rpx;
}

.week-item {
  text-align: center;
  font-size: 22rpx;
  color: #9ca3af;
}

/* 日期网格 */
.day-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  row-gap: 12rpx;
  column-gap: 0;
  margin-top: 8rpx;
}

.day-cell {
  height: 72rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.day-inner {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

/* 有日程但未关联企划时，在日期下方显示圆点（与完成圆点同款、黑色） */
.day-dot-no-project {
  position: absolute;
  left: 50%;
  top: 81%;
  transform: translate(-50%, -50%);
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #111827;
}

/* 有完成项目时在日期数字下方显示圆点（同款、深粉色） */
.day-heart-dot {
  position: absolute;
  left: 50%;
  top: 81%;
  transform: translate(-50%, -50%);
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: rgb(244, 139, 206);
}

/* 当前月日期默认底色（有日程时由内联 style 覆盖为项目色） */
.day-current-month .day-inner {
  background-color: #f9fafb;
}

/* 其他月占位日期（淡） */
.day-other-month .day-inner {
  opacity: 0.3;
}

/* 日期数字 */
.day-number {
  font-size: 24rpx;
  color: #111827;
}

/* 月底部说明 */
.month-footer {
  margin-top: 16rpx;
}

.month-hint {
  font-size: 22rpx;
  color: #9ca3af;
}

/* 企划封面整体卡片（上下圆角） */
.cover-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 24rpx 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.06);
}

/* 封面网格：3 列 */
.cover-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-row-gap: 24rpx;
  grid-column-gap: 16rpx;
}

/* 单个封面（整列宽度一致，便于点与封面左缘对齐） */
.cover-item {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  width: 100%;
}

/* 正方形封面容器（裁切左上角绶带） */
.cover-square {
  width: 100%;
  position: relative;
  overflow: hidden;
  border-radius: 18rpx;
}

.cover-square::before {
  content: "";
  display: block;
  padding-top: 100%;
}

.cover-image,
.cover-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 18rpx;
  overflow: hidden;
}

/* 左上角三角（直角在左上，颜色由 border-top-color 传入） */
.cover-ribbon {
  position: absolute;
  left: 0;
  top: 0;
  width: 0;
  height: 0;
  border-width: 48rpx 48rpx 0 0;
  border-style: solid;
  border-color: transparent;
  border-right-color: transparent;
  z-index: 2;
}

/* 封面右下角：项目目前进度 */
.cover-progress {
  position: absolute;
  right: 0;
  bottom: 0;
  padding: 4rpx 8rpx;
  font-size: 18rpx;
  color: #fff;
  background-color: rgba(17, 24, 39, 0.72);
  border-top-left-radius: 8rpx;
  z-index: 2;
  line-height: 1.2;
}

/* 名字一行：企划名整列居中 */
.cover-label-row {
  margin-top: 12rpx;
  position: relative;
  width: 100%;
  min-height: 28rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

/* 项目名称下的项目标记（色点） */
.cover-tag-row {
  margin-top: 6rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.cover-tag-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

/* 实际图片 */
.cover-image {
  width: 100%;
  height: 100%;
}

/* “+” 占位 */
.cover-placeholder {
  border: 1rpx dashed #d1d5db;
  background-color: #f9fafb;
  display: flex;
  justify-content: center;
  align-items: center;
}

.cover-plus {
  font-size: 40rpx;
  color: #9ca3af;
}

/* 封面文字：整列居中，字稍大 */
.cover-label {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 28rpx;
  line-height: 1.2;
  color: #4b5563;
  text-align: center;
  padding: 0;
  margin: 0;
}

.cover-label-sm {
  font-size: 22rpx;
}

/* 底部提示 */
.cover-tip {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #9ca3af;
}